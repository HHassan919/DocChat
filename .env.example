# ==============================================================================
# DocChat — Environment Variables Reference
# Copy this file to .env (backend) and frontend/.env.local (frontend)
# Never commit .env or .env.local — they are in .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# HuggingFace (Optional — improves rate limits on free tier)
# Get a free token at: https://huggingface.co/settings/tokens
# Without this token the app still works, but may hit anonymous rate limits
# ------------------------------------------------------------------------------
HF_API_TOKEN=

# ------------------------------------------------------------------------------
# Backend server port (used by Render and Docker; defaults to 8000 locally)
# ------------------------------------------------------------------------------
PORT=8000

# ------------------------------------------------------------------------------
# CORS — Frontend origin allowed to talk to the backend
# Local dev: http://localhost:3000
# Production: your Vercel URL, e.g. https://docchat.vercel.app
# ------------------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:3000

# ------------------------------------------------------------------------------
# Frontend — Backend API URL
# Local dev: http://localhost:8000
# Production: your Render backend URL
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Optional — visitor-provided keys are passed per-request and never stored
# These are documented here so the deployment team knows what to expect
# Do NOT set these as server environment variables — they come from the UI
# ------------------------------------------------------------------------------
# OPENAI_API_KEY=      (passed by visitor per request, not stored)
# GOOGLE_API_KEY=      (passed by visitor per request, not stored)
